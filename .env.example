# ==============================================================================
# 🚀 DELL E-PORT — ENVIRONMENT CONFIGURATION
# Copy this file: cp .env.example .env
# Then edit .env with your actual values (never commit .env to git!)
# ==============================================================================

# ------------------------------------------------------------------------------
# 📸 IMMICH — PHOTO SERVER
# ------------------------------------------------------------------------------

# Where your photos will be stored on the server
# This should point to your large drive mount (e.g., a 310GB HDD)
# Example: /mnt/vault2 or /mnt/photos
UPLOAD_LOCATION=/mnt/photos

# Immich version tag — keep as "release" to always pull the latest stable
IMMICH_VERSION=release

# ------------------------------------------------------------------------------
# 🗄️ DATABASE (PostgreSQL)
# ------------------------------------------------------------------------------

# Strong random password for the Immich Postgres database
# Generate one with: openssl rand -base64 32
DB_PASSWORD=your_secure_database_password_here

# ------------------------------------------------------------------------------
# ⚠️  HARDWARE NOTES (READ THIS)
# ------------------------------------------------------------------------------
# Intel QuickSync (Jellyfin transcoding): uses /dev/dri/renderD128
# This device path is specific to THIS machine.
# Run: ls /dev/dri/ on your server to find yours before starting.
#
# AMD GPU (Immich ML) is currently DISABLED in docker-compose.yml
# Uncomment the immich-machine-learning block only if your GPU is stable.
# ------------------------------------------------------------------------------
#
# Path to your existing photo library (Immich will index but not move these)
# Remove the external volume in docker-compose.yml if you don't have one
EXTERNAL_LIBRARY_PATH=/mnt/your-drive/Photos

# Jellyfin media paths
JELLYFIN_MOVIES_PATH=/mnt/your-drive/videos
JELLYFIN_MUSIC_PATH=/mnt/your-drive/music

# Timezone (default: Asia/Kolkata)
TIMEZONE=Asia/Kolkata
